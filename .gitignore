# Rails Engine .gitignore

# Bundler
/.bundle
/vendor/bundle

# RubyGems
*.gem

# Documentation
/.yardoc
/doc/
/rdoc

# Test coverage
/coverage

# Editor files
*.swp
*.swo
*~
.DS_Store
/*.vim
.idea/
.vscode/

# Ruby LSP
/.ruby-lsp

# Schema (auto-generated by host app, not meaningful in the engine repo)
/db/schema.rb

# Temporary files (if they get created during development)
/log
/tmp
