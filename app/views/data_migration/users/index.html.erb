<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Users</h1>
  <%= link_to "New User", '/data_migration/users/new', class: "btn btn-primary" %>
</div>

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td>
            <span class="badge bg-<%= user.admin? ? 'danger' : (user.operator? ? 'primary' : 'secondary') %>">
              <%= user.role.titleize %>
            </span>
          </td>
          <td><%= time_ago_in_words(user.created_at) %> ago</td>
          <td>
            <%= link_to "Edit", '/data_migration/users/' + user.id.to_s + '/edit', class: "btn btn-sm btn-outline-warning" %>
            <% if user != current_user %>
              <%= button_to "Delete", '/data_migration/users/' + user.id.to_s,
                  method: :delete,
                  class: "btn btn-sm btn-outline-danger",
                  data: { confirm: "Are you sure?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
