<h1 class="mb-4">User Management</h1>

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th>Email</th>
        <th>Role</th>
        <th>Confirmed</th>
        <th>Executions</th>
        <th>Joined</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td>
            <%= link_to user.email, user, class: "text-decoration-none" %>
            <% if user.id == current_user.id %>
              <span class="badge bg-info">You</span>
            <% end %>
          </td>
          <td>
            <span class="badge bg-<%= user.admin? ? 'danger' : (user.operator? ? 'warning' : 'secondary') %>">
              <%= user.role.titleize %>
            </span>
          </td>
          <td>
            <% if user.confirmed? %>
              <span class="text-success">✓ Yes</span>
            <% else %>
              <span class="text-warning">⚠ Pending</span>
            <% end %>
          </td>
          <td>
            <span class="badge bg-secondary"><%= user.migration_executions.count %></span>
          </td>
          <td>
            <small><%= user.created_at.strftime("%Y-%m-%d") %></small>
          </td>
          <td>
            <% if policy(user).show? %>
              <%= link_to "View", user, class: "btn btn-sm btn-outline-primary" %>
            <% end %>
            <% if policy(user).destroy? && user.id != current_user.id %>
              <%= button_to "Delete", user,
                  method: :delete,
                  class: "btn btn-sm btn-outline-danger",
                  data: { confirm: "Delete #{user.email}?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
